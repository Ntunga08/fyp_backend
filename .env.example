# ─── Database ─────────────────────────────────────────────────────────────────
# On Render this is injected automatically from the linked PostgreSQL service.
DATABASE_URL="postgresql://user:password@host:5432/edutrack"

# ─── JWT ──────────────────────────────────────────────────────────────────────
# Generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET="replace-with-a-long-random-string"
JWT_EXPIRES_IN="7d"

# ─── Server ───────────────────────────────────────────────────────────────────
PORT=3000
NODE_ENV=production

# ─── Email (SMTP) ─────────────────────────────────────────────────────────────
# Set SMTP_ENABLED=true to send real emails.
# When false, emails are logged to console only (safe for development).
SMTP_ENABLED=false
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
# Gmail: use an App Password (Google Account → Security → App Passwords)
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password
EMAIL_FROM="EduTrack <noreply@yourdomain.tz>"

# Public URL of this backend (used inside email links)
APP_URL=https://edutrack-backend.onrender.com
